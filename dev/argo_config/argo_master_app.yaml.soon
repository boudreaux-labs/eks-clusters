apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: argocd-config
  namespace: argocd

spec:
  project: default

  source:
    repoURL: https://gitlab.env.io/center-of-enablement/eks/addons/workloads/tamarac.git
    targetRevision: main
    path: tamsharedprod/argocd-config

  destination:
    server: https://kubernetes.default.svc
    namespace: argocd

  syncPolicy:
    automated: {}